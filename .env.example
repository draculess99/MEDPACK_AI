# MedPack AI local defaults — safe/no-token mode
MEDPACK_LOCAL_API_BASE_URL=http://127.0.0.1:5001
MEDPACK_BACKEND_TARGET=Local Backend
DEFAULT_AGENT_MODE=local
USE_LLM_AGENTS=false

# Optional deployed backend URL for the Streamlit sidebar Remote Backend option
# MEDPACK_REMOTE_API_BASE_URL=https://your-medpack-backend.up.railway.app

# Optional remote LLM mode. Only set these when you intentionally want token usage.
# USE_LLM_AGENTS=true
# GEMINI_API_KEY=your_key_here
# GEMINI_MODEL=gemini-1.5-flash

# Safety guard: keep the committee button local so the dashboard does not hang on remote/streaming LLM calls.
MEDPACK_FORCE_LOCAL_COMMITTEE=true

MEDPACK_ALLOW_FULL_COMMITTEE_ROUTE=false

MEDPACK_ALLOW_COMMITTEE_STREAM=false

# Stage 3 supplier/transfer intelligence is local demo logic and does not use tokens.
MEDPACK_STAGE3_ENABLED=true
