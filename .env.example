# MedPack AI local defaults — safe/no-token mode
MEDPACK_LOCAL_API_BASE_URL=http://127.0.0.1:5001
MEDPACK_BACKEND_TARGET=Local Backend
DEFAULT_AGENT_MODE=local
USE_LLM_AGENTS=false

# Optional deployed backend URL for the Streamlit sidebar Remote Backend option
# MEDPACK_REMOTE_API_BASE_URL=https://your-medpack-backend.up.railway.app

# Optional remote LLM mode. Only set these when you intentionally want token usage.
# USE_LLM_AGENTS=true
# GEMINI_API_KEY=your_key_here
# GEMINI_MODEL=gemini-1.5-flash
